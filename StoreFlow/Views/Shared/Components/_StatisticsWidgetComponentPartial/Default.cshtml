<div class="row d-flex align-items-stretch">

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-chart-line text-primary mr-2"></i>
                    Toplam Kategori Sayısı
                </h4>
                <br />
                <h2 class="mb-0">@ViewBag.categoryCount</h2>
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-shopping-cart text-success mr-2"></i>
                    Maximum Fiyatlı Ürün
                </h4>
                <br />
                <h2 class="mb-0"> TL @ViewBag.productMaxPrice</h2>
                <small class="text-muted mt-auto">
                    Bu Ürün : @ViewBag.ProducMaxPriceProductName
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-tags text-warning mr-2"></i>
                    Minimum Fiyatlı Ürün
                </h4>
                <br />
                <h2 class="mb-0"> TL @ViewBag.productMinPrice</h2>
                <small class="text-muted mt-auto">
                    Bu Ürün : @ViewBag.productMinPriceProductName
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-exclamation-triangle text-warning mr-2"></i>
                    Stoğu Düşen Ürün/Ürünler
                </h4>
                <br />
                <h2 class="mb-0">  @ViewBag.LowStockProducts.Count </h2>
                <small class="text-muted mt-auto">
                    Bu Ürün/Ürünler : @string.Join(", ", ((List<Product>)ViewBag.LowStockProducts).Select(p => p.ProductName))
                </small>
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-boxes text-info mr-2"></i>
                    Toplam Ürün Stok Seviyesi
                </h4>
                <br />
                <h2 class="mb-0">
                    @ViewBag.TotalSumProductStock
                </h2>

                <small class="text-muted mt-auto">
                    @if ((double)ViewBag.StockTrend > 0)
                    {
                        <span class="text-success">
                            <i class="fas fa-arrow-up"></i> Stok güçleniyor
                        </span>
                    }
                    else if ((double)ViewBag.StockTrend < 0)
                    {
                        <span class="text-danger">
                            <i class="fas fa-arrow-down"></i> Stok düşüyor
                        </span>
                    }
                    else
                    {
                        <span class="text-warning">
                            <i class="fas fa-minus"></i> Stabil
                        </span>
                    }
                </small>
                
            </div>
        </div>
    </div>

    <div class="col-md-4 grid-margin d-flex">
        <div class="card w-100">
            <div class="card-body d-flex flex-column">
                <h4 class="card-title mb-0">
                    <i class="fas fa-coins text-success mr-2"></i>
                    Toplam Ürün Stok Değeri
                </h4>
                <br />
                <h2 class="mb-0">
                    @(((decimal)ViewBag.TotalStockValue).ToString("N2")) TL
                </h2>
                <small class="text-muted mt-auto">

                </small>
            </div>
        </div>
    </div>
    <div class="card mt-4">
        <div class="card-body">
            <h4 class="card-title">
                <i class="fas fa-chart-line text-primary mr-2"></i>
                7 Günlük Stok Trendi
            </h4>

            <canvas id="stockChart"></canvas>
        </div>
    </div>

</div>